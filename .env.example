# BTC Monitor Environment Variables

# MACRO DATA (Required for Liquidity Metrics)
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# FUND FLOWS (Optional, will use fallback scraper if missing)
# COINGLASS_API_KEY=your_coinglass_api_key_here

# OPTIONS DATA (Optional, ETF options fallback if set)
# TRADIER_API_TOKEN=your_tradier_api_token

# NOTIFICATIONS (Optional)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# STRATEGY TUNING (Optional, defaults provided in config.py)
# THRESHOLD_BUY=60
# THRESHOLD_SELL=-40
# MAX_BUDGET_MULTIPLIER=3.0
